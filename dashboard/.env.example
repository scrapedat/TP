# Here’s what your .env.example file should look like:


# Ollama API Configuration
OLLAMA_API_BASE_URL=http://localhost:11434/api

# Database URL (SQLite default)
DATABASE_URL=sqlite:///./sql_app.db

# JWT Authentication
# The SECRET_KEY will be generated by the setup.sh script
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# The Workflow
 
# * user clones repository from GitHub.
# * There is no .env file, only a .env.example file.
# * user runs setup.sh script.
# * The script creates a brand new .env file and populates it, including generating a unique SECRET_KEY.
# * The application is now ready to run.

